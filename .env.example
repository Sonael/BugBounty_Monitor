# ============================================================
# .env.example — copie para .env e preencha com seus valores
# ============================================================

# ── Banco de Dados (PostgreSQL) ──────────────────────────────
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completa usada pelo SQLAlchemy
DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@db:5432/your_database_name

# ── Redis / Celery ───────────────────────────────────────────
# db=0: Celery broker (filas de tarefas)
# db=1: Cache Python (crt.sh, etc.)
# db=2: Flask-Limiter (contagem de rate limit)
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_HOST=redis

# ── Flask ────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ── Usuário Administrador Inicial ────────────────────────────
# Criado automaticamente no primeiro boot. Use senha forte.
ADMIN_USER=admin_username
ADMIN_PASSWORD=strong_admin_password

# ── Notificações Discord ─────────────────────────────────────
# Webhook do canal onde as notificações serão enviadas
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ── Naabu (Port Scan) ────────────────────────────────────────
# Controles do chunking para projetos com muitos subdomínios
# Aumente NAABU_CHUNK_SIZE se o servidor tiver mais memória/CPU
NAABU_CHUNK_SIZE=500
NAABU_CHUNK_TIMEOUT=600
NAABU_RATE=1000

# ── Configurações das Ferramentas de Scan ────────────────────────────────────

# Subfinder
SUBFINDER_THREADS=100

# Amass
AMASS_TIMEOUT=29

# HTTPX
HTTPX_THREADS=50

# Naabu
NAABU_CHUNK_SIZE=500
NAABU_CHUNK_TIMEOUT=600
NAABU_RATE=1000
NAABU_TOP_PORTS=100
NAABU_RETRIES=1
NAABU_PKT_TIMEOUT=5

# Nuclei
NUCLEI_TAGS=cve,misconfig,exposure,tech,panel,xss,sqli,lfi,ssrf,rce,oast,takeover,default-login,fuzzing
NUCLEI_SEVERITY=low,medium,high,critical
NUCLEI_CONCURRENCY=50
NUCLEI_TIMEOUT=10
NUCLEI_RETRIES=2

# Katana (usado pelo Dalfox e SQLMap)
KATANA_DEPTH=3

# Dalfox
DALFOX_TIMEOUT=10

# SQLMap
SQLMAP_RISK=2
SQLMAP_LEVEL=3
SQLMAP_THREADS=4

# FFuf
FFUF_MAXTIME=90

# GAU
GAU_BLACKLIST=png,jpg,jpeg,gif,css,svg,woff,woff2,ico,ttf,eot

# Session lifetime (ex: 30m, 1h, 1d)
SESSION_DAYS=30